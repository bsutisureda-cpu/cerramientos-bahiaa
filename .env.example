# Credenciales de acceso a la app (se configuran en Railway > Variables)
USUARIO=admin
CLAVE=cambiar-esta-clave

# Opcional: clave secreta usada para firmar la cookie de sesión.
# Si no se define, se usa USUARIO:CLAVE como secreto (funciona, pero es mejor definir una propia).
SESSION_SECRET=una-cadena-larga-y-aleatoria

# Carpeta donde se guardan config.json y las imágenes subidas.
# En Railway: la ruta donde montaste el Volume (ej. /data). En local, se puede omitir.
DATA_DIR=./data
