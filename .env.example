# Credenciales de acceso a la app (se configuran en Railway > Variables)
USUARIO=admin
CLAVE=cambiar-esta-clave

# Opcional: clave secreta usada para firmar la cookie de sesión.
# Si no se define, se usa USUARIO:CLAVE como secreto (funciona, pero es mejor definir una propia).
SESSION_SECRET=una-cadena-larga-y-aleatoria

# Carpeta donde se guardan config.json y las imágenes subidas.
# En Railway: la ruta donde montaste el Volume (ej. /data). En local, se puede omitir.
DATA_DIR=./data

# --- Bot de Telegram (Excel de Winmaker -> PDF) ---------------------------
# Si TELEGRAM_TOKEN está vacío, el bot simplemente no arranca y la app funciona igual.

# Token que da @BotFather al crear el bot. Es secreto: cargarlo sólo en Railway.
TELEGRAM_TOKEN=

# IDs de Telegram que pueden usar el bot, separados por coma (los da @userinfobot).
# Si está vacío, el bot no le responde a nadie.
TELEGRAM_ALLOWED=

# Opcional: ruta a un Chromium del sistema. Si se omite, se usa el que baja puppeteer.
PUPPETEER_EXECUTABLE_PATH=
